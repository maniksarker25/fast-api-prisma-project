generator client {
  provider = "prisma-client-py"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String @id @default(cuid())
  title       String
  description String
  price       Float
  stock       Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
